/*
  X-Robots-Tag: noindex, nofollow

/*.html
  Cache-Control: public, max-age=0, must-revalidate

# The service worker must NEVER be cached. If a browser holds on to an old sw.js it
# keeps running the old worker, and push registration silently breaks after a deploy.
/sw.js
  Cache-Control: public, max-age=0, must-revalidate
  Service-Worker-Allowed: /

/manifest.webmanifest
  Content-Type: application/manifest+json
  Cache-Control: public, max-age=0, must-revalidate

# Icons are versioned in the URL (?v=N), so a change always looks like a new file.
# The cache is kept SHORT anyway — iOS is notoriously stubborn about re-fetching
# apple-touch-icon, and a week-long cache is what left the old icon on the phone.
/icons/*
  Cache-Control: public, max-age=3600, must-revalidate
